# Base de datos
DATABASE_URL=postgresql://usuario:contraseña@host:5432/menuapp

# Spoonacular — https://spoonacular.com/food-api/console
SPOONACULAR_API_KEY=tu_key_aqui

# Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=tu_key_aqui

# Google Cloud Vision — https://console.cloud.google.com
# Local: ruta al JSON del service account
GOOGLE_CLOUD_KEY_FILE=./google-vision-key.json
# Railway: pega el JSON completo del service account
# GOOGLE_CLOUD_CREDENTIALS={"type":"service_account",...}
# O usa una API key directa:
# GOOGLE_VISION_API_KEY=tu_api_key

GOOGLE_CLOUD_PROJECT_ID=tu_project_id

# Servidor
PORT=3000
NODE_ENV=development
